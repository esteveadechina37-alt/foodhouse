---
// Footer Premium - FoodHouse
---

<footer class="bg-noir text-creme pt-28 pb-12 relative overflow-hidden" id="footer-observer">
  <!-- Ligne décorative supérieure -->
  <div class="absolute top-0 left-6 right-6 md:left-12 md:right-12 h-px bg-creme/10"></div>

  <!-- Brume lumineuse subtile -->
  <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-96 h-96 bg-vin/5 rounded-full filter blur-[150px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <div class="grid md:grid-cols-3 gap-16 mb-16">

      <!-- Colonne 1 : Logo + description -->
      <div class="footer-reveal">
        <a href="#" class="group inline-flex items-center gap-3 mb-5">
          <div class="relative w-10 h-10 flex items-center justify-center border border-vin/30 rounded-full group-hover:border-vin transition-colors duration-500">
            <span class="font-serif text-sm font-bold text-vin tracking-tighter">FH</span>
            <div class="absolute -top-1 left-1/2 -translate-x-1/2 w-1 h-1 bg-vin rounded-full"></div>
            <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-1 h-1 bg-vin rounded-full"></div>
          </div>
          <span class="text-2xl font-serif font-bold tracking-wide text-creme">
            Food<span class="text-vin">House</span>
          </span>
        </a>
        <p class="text-creme/50 text-sm leading-relaxed max-w-xs">
          Une expérience culinaire africaine raffinée, où les épices et les saveurs authentiques rencontrent l'élégance contemporaine.
        </p>
      </div>

      <!-- Colonne 2 : Navigation -->
      <div class="footer-reveal" style="transition-delay: 0.1s;">
        <h3 class="text-xs uppercase tracking-[0.3em] text-creme/40 font-semibold mb-6">Navigation</h3>
        <ul class="space-y-4">
          <li><a href="#experience" class="text-creme/60 hover:text-vin transition-colors text-sm">À propos</a></li>
          <li><a href="#menu" class="text-creme/60 hover:text-vin transition-colors text-sm">La Carte</a></li>
          <li><a href="#galerie" class="text-creme/60 hover:text-vin transition-colors text-sm">Galerie</a></li>
          <li><a href="#reservation" class="text-creme/60 hover:text-vin transition-colors text-sm">Réservation</a></li>
        </ul>
      </div>

      <!-- Colonne 3 : Contact rapide + Réseaux -->
      <div class="footer-reveal" style="transition-delay: 0.2s;">
        <h3 class="text-xs uppercase tracking-[0.3em] text-creme/40 font-semibold mb-6">Contact</h3>
        <ul class="space-y-3 text-sm text-creme/60">
          <li>Porto-Novo</li>
          <li>République du Bénin</li>
          <li class="pt-2">
            <a href="tel:+2290196977215" class="hover:text-vin transition-colors">+229 01 96 97 72 15</a>
          </li>
          <li>
            <a href="mailto:contact@foodhouse.bj" class="hover:text-vin transition-colors">contact@foodhouse.bj</a>
          </li>
        </ul>
        <!-- Réseaux sociaux -->
        <div class="flex gap-4 mt-6">
          <a href="#" aria-label="Instagram" class="w-9 h-9 rounded-full border border-creme/20 flex items-center justify-center hover:border-vin hover:text-vin transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" aria-label="Facebook" class="w-9 h-9 rounded-full border border-creme/20 flex items-center justify-center hover:border-vin hover:text-vin transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="#" aria-label="TikTok" class="w-9 h-9 rounded-full border border-creme/20 flex items-center justify-center hover:border-vin hover:text-vin transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 8 0 4 4 0 0 0-8 0z"/><path d="M15 8h.01"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bas de footer : Copyright + Médaillon -->
    <div class="border-t border-creme/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 footer-reveal" style="transition-delay: 0.3s;">
      <p class="text-creme/30 text-xs tracking-wider">
        &copy; 2026 FoodHouse. Tous droits réservés.
      </p>
      <div class="flex items-center gap-2 text-creme/40 text-xs">
        <span>Design par</span>
        <span class="text-vin font-semibold">FoodHouse</span>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  const footerObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const nodes = entry.target.querySelectorAll('.footer-reveal');
        nodes.forEach((node) => node.classList.add('reveal-active'));
        footerObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  const footerTarget = document.getElementById('footer-observer');
  if (footerTarget) {
    footerObserver.observe(footerTarget);
  }
</script>

<style is:global>
  .footer-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s cubic-bezier(0.19, 1, 0.22, 1),
                transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);
    will-change: transform, opacity;
  }
  .footer-reveal.reveal-active {
    opacity: 1;
    transform: translateY(0);
  }
</style>