---
// Version finale : Carrousel 3D horizontal avec flou d'arrière-plan activé UNIQUEMENT sur Desktop
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-noir premium-grain" id="hero-scene">

  <!-- Image de fond avec effet parallaxe discret -->
  <div class="absolute inset-0 z-0 scale-110" id="parallax-bg">
    <img
      src="https://images.unsplash.com/photo-1552566626-52f8b828add9?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80"
      alt="Ambiance FoodHouse"
      class="w-full h-full object-cover animate-kenburns select-none pointer-events-none"
    />
    <!-- MODIFICATION : md:backdrop-blur-md applique le flou uniquement sur écran d'ordinateur (>= 768px) -->
    <div class="absolute inset-0 bg-noir/20 md:bg-noir/40 md:backdrop-blur-md z-1"></div>
    <div class="absolute inset-0 bg-linear-to-t from-noir via-noir/70 to-noir/20 z-2"></div>
    <div class="absolute inset-0 bg-linear-to-r from-noir/95 via-noir/40 to-transparent z-2"></div>
  </div>

  <!-- Le contenu passe en z-10 pour rester net au-dessus du flou d'arrière-plan -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 w-full">
    <div class="grid md:grid-cols-2 items-center gap-16">

      <!-- Colonne 1 : Le Texte (Reste 100% protégé et intact) -->
      <div class="max-w-xl z-10">
        <div class="flex items-center gap-4 mb-6 stagger-item opacity-0" style="animation-delay: 0.15s;">
          <span class="h-[1px] w-8 bg-vin"></span>
          <span class="uppercase tracking-[0.4em] text-[10px] text-creme/60 font-semibold">Cuisine africaine d'exception</span>
        </div>
        
        <h1 class="font-serif text-5xl md:text-7xl text-creme mb-6 tracking-wide stagger-item opacity-0 leading-none" style="animation-delay: 0.3s;">
          Food<span class="text-vin font-light italic tracking-tight">House</span>
        </h1>
        
        <p class="text-creme/60 text-base md:text-lg mb-10 max-w-md font-light leading-relaxed stagger-item opacity-0" style="animation-delay: 0.45s;">
          Là où les épices ancestrales du continent rencontrent l'exigence de la haute table moderne.
        </p>
        
        <div class="flex flex-wrap gap-5 stagger-item opacity-0" style="animation-delay: 0.6s;">
          <a href="#" class="bg-vin hover:bg-vin/90 text-white font-medium text-sm tracking-wider uppercase py-4 px-9 transition-all duration-300 shadow-2xl shadow-vin/10 hover:shadow-vin/30 border border-vin">
            Réserver
          </a>
          <a href="#" class="border border-creme/20 text-creme hover:text-white hover:border-creme/60 font-medium text-sm tracking-wider uppercase py-4 px-9 transition-all duration-300">
            Découvrir le Menu
          </a>
        </div>
      </div>

      <!-- Colonne 2 : Carrousel 3D Horizontal (Isolé sur la droite) -->
      <div class="relative hidden md:flex justify-center items-center overflow-visible select-none pointer-events-none" style="height: 450px;" id="parallax-wheel">
        
        <div class="premium-slider-3d">
          
          <!-- Plat 1 -->
          <div class="slider-card sc-1">
            <img src="/images/plats/plat-1.png" alt="Plat 1" class="w-52 h-52 object-contain dish-filter" />
          </div>
          
          <!-- Plat 2 -->
          <div class="slider-card sc-2">
            <img src="/images/plats/plat-2.png" alt="Plat 2" class="w-52 h-52 object-contain dish-filter" />
          </div>
          
          <!-- Plat 3 -->
          <div class="slider-card sc-3">
            <img src="/images/plats/plat-3.png" alt="Plat 3" class="w-52 h-52 object-contain dish-filter" />
          </div>

        </div>
      </div>

    </div>
  </div>

</section>

<script>
  // Effet de parallaxe sur la scène (Uniquement sur ordinateur)
  const heroScene = document.getElementById('hero-scene');
  const bg = document.getElementById('parallax-bg');
  const wheel = document.getElementById('parallax-wheel');

  if (heroScene && window.innerWidth > 768) {
    heroScene.addEventListener('mousemove', (e) => {
      const { clientX, clientY } = e;
      const { innerWidth, innerHeight } = window;
      
      const x = (clientX / innerWidth) - 0.5;
      const y = (clientY / innerHeight) - 0.5;

      if (bg) bg.style.transform = `scale(1.1) translate(${x * 15}px, ${y * 15}px)`;
      if (wheel) wheel.style.transform = `translate(${x * -25}px, ${y * -15}px)`;
    });
  }
</script>

<style is:global>
  :root { --noir: #090909; --vin: #630f25; --creme: #f9f6f0; }
  .bg-noir { background-color: var(--noir); }
  .bg-vin { background-color: var(--vin); }
  .text-vin { color: var(--vin); }
  .text-creme { color: var(--creme); }

  /* Grain cinéma argentique en arrière-plan */
  .premium-grain::before {
    content: "";
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.02;
    z-index: 3;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://w3.org id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  }

  .dish-filter {
    filter: drop-shadow(0 30px 25px rgba(0, 0, 0, 0.5));
  }

  .premium-slider-3d {
    position: relative;
    width: 100%;
    height: 100%;
    perspective: 1200px;
    transform-style: preserve-3d;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .slider-card {
    position: absolute;
    transform-style: preserve-3d;
    will-change: transform, opacity, filter;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 240px;
    height: 240px;
  }

  .sc-1 { animation: slide3D-1 18s cubic-bezier(0.76, 0, 0.24, 1) infinite; }
  .sc-2 { animation: slide3D-2 18s cubic-bezier(0.76, 0, 0.24, 1) infinite; }
  .sc-3 { animation: slide3D-3 18s cubic-bezier(0.76, 0, 0.24, 1) infinite; }

  @keyframes slide3D-1 {
    0%, 28%    { transform: translateX(0) translateZ(100px) scale(1.1); opacity: 1; filter: blur(0); z-index: 30; }
    33%, 61%   { transform: translateX(160px) translateZ(-150px) scale(0.85); opacity: 0.35; filter: blur(4px); z-index: 10; }
    66%, 94%   { transform: translateX(-160px) translateZ(-150px) scale(0.85); opacity: 0.35; filter: blur(4px); z-index: 10; }
    100%       { transform: translateX(0) translateZ(100px) scale(1.1); opacity: 1; filter: blur(0); z-index: 30; }
  }

  @keyframes slide3D-2 {
    0%, 28%    { transform: translateX(160px) translateZ(-150px) scale(0.85); opacity: 0.35; filter: blur(4px); z-index: 10; }
    33%, 61%   { transform: translateX(-160px) translateZ(-150px) scale(0.85); opacity: 0.35; filter: blur(4px); z-index: 10; }
    66%, 94%   { transform: translateX(0) translateZ(100px) scale(1.1); opacity: 1; filter: blur(0); z-index: 30; }
    100%       { transform: translateX(160px) translateZ(-150px) scale(0.85); opacity: 0.35; filter: blur(4px); z-index: 10; }
  }

  @keyframes slide3D-3 {
    0%, 28%    { transform: translateX(-160px) translateZ(-150px) scale(0.85); opacity: 0.35; filter: blur(4px); z-index: 10; }
    33%, 61%   { transform: translateX(0) translateZ(100px) scale(1.1); opacity: 1; filter: blur(0); z-index: 30; }
    66%, 94%   { transform: translateX(160px) translateZ(-150px) scale(0.85); opacity: 0.35; filter: blur(4px); z-index: 10; }
    100%       { transform: translateX(-160px) translateZ(-150px) scale(0.85); opacity: 0.35; filter: blur(4px); z-index: 10; }
  }

  .animate-kenburns { animation: kenburns 30s ease-out infinite alternate; }
  @keyframes kenburns { 0% { transform: scale(1); } 100% { transform: scale(1.06); } }

  .stagger-item { animation: premiumReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  @keyframes premiumReveal { 
    from { opacity: 0; transform: translateY(35px); filter: blur(5px); } 
    to { opacity: 1; transform: translateY(0); filter: blur(0); } 
  }
</style>
