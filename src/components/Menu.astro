---
// Section Menu Haute Gastronomie - Design Tendance "Split-Gallery Asymétrique"
---

<section id="menu" class="py-28 md:py-40 bg-noir relative overflow-hidden text-creme">
  
  <!-- Brume lumineuse d'ambiance d'un bordeaux très profond -->
  <div class="absolute top-1/3 right-0 w-[600px] h-[600px] bg-vin/10 rounded-full filter blur-[160px] pointer-events-none select-none"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-vin/5 rounded-full filter blur-[130px] pointer-events-none select-none"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10" id="premium-menu-observer">
    
    <!-- En-tête Format Galerie de Luxe -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-32 gap-6 menu-reveal-node">
      <div>
        <span class="uppercase tracking-[0.6em] text-[9px] text-vin font-bold block mb-3">La Collection Privée</span>
        <h2 class="font-serif text-5xl md:text-7xl font-extralight tracking-tight leading-none">
          L'Art de <br class="hidden md:inline"/><span class="italic font-light text-vin">la Table</span>
        </h2>
      </div>
      <p class="text-creme/40 max-w-xs font-light text-xs md:text-sm leading-relaxed border-l border-creme/10 pl-6">
        Une réécriture contemporaine des grands classiques du continent africain.
      </p>
    </div>

    <!-- Grille Asymétrique Inspirée des Magazines de Mode -->
    <div class="grid md:grid-cols-12 gap-y-32 md:gap-x-16 items-start">
      
      <!-- PLAT 1 : Le Ceebu Jën (Position Haute - Gauche) -->
      <div class="md:col-span-5 space-y-8 menu-reveal-node" style="transition-delay: 0.1s;">
        <!-- Cadre vertical élancé -->
        <div class="relative aspect-[3/4] w-full overflow-hidden bg-neutral-950 border border-creme/5 group cursor-pointer">
          <img 
            src="/images/plats/plat-5.png" 
            alt="Le Ceebu Jën Originel" 
            class="w-full h-full object-cover opacity-75 group-hover:opacity-100 group-hover:scale-103 transition-all duration-1000 ease-out filter contrast-110" 
          />
          <!-- Voile dégradé cinéma -->
          <div class="absolute inset-0 bg-linear-to-t from-noir via-transparent to-transparent opacity-60 group-hover:opacity-20 transition-opacity duration-700"></div>
        </div>
        
        <div class="space-y-3 pt-2">
          <div class="flex justify-between items-baseline">
            <h3 class="font-serif text-3xl font-light tracking-wide group-hover:text-vin transition-colors">Ceebu Jën</h3>
            <span class="font-serif text-lg text-vin tracking-widest">8 000 FCFA</span>
          </div>
          <p class="text-creme/50 text-sm font-light leading-relaxed max-w-md">
            Riz mûri dans un court-bouillon de thiof noble infusé aux herbes du Sine Saloum, textures de légumes oubliés glacés et réduction de tamarin confit.
          </p>
          <div class="text-[9px] uppercase tracking-[0.3em] text-creme/30 font-semibold pt-1">Héritage Sénégalais</div>
        </div>
      </div>

      <!-- ESPACE VIDE DE TRANSITION POUR L'ASYMÉTRIE SUR DESKTOP -->
      <div class="hidden md:block md:col-span-2"></div>

      <!-- PLAT 2 : L'Attiéké Translucide (Position Centrée Décalée - Droite) -->
      <div class="md:col-span-5 space-y-8 md:mt-24 menu-reveal-node" style="transition-delay: 0.25s;">
        <div class="relative aspect-[3/4] w-full overflow-hidden bg-neutral-950 border border-creme/5 group cursor-pointer">
          <img 
            src="/images/plats/plat-6.png" 
            alt="L'Attiéké Translucide" 
            class="w-full h-full object-cover opacity-75 group-hover:opacity-100 group-hover:scale-103 transition-all duration-1000 ease-out filter contrast-110" 
          />
          <div class="absolute inset-0 bg-linear-to-t from-noir via-transparent to-transparent opacity-60 group-hover:opacity-20 transition-opacity duration-700"></div>
        </div>
        
        <div class="space-y-3 pt-2">
          <div class="flex justify-between items-baseline">
            <h3 class="font-serif text-3xl font-light tracking-wide">L'Attiéké</h3>
            <span class="font-serif text-lg text-vin tracking-widest">5 500 FCFA</span>
          </div>
          <p class="text-creme/50 text-sm font-light leading-relaxed max-w-md">
            Manioc de tabou affiné travaillé en grains de soie aériens, pavé de capitaine rôti sur peau, condiments vierges aux piments doux locaux et oignons rouges acidulés.
          </p>
          <div class="text-[9px] uppercase tracking-[0.3em] text-creme/30 font-semibold pt-1">Épure Ivoirienne</div>
        </div>
      </div>

      <!-- PLAT 3 : Le Ndolé (Centré en bas sur une large colonne) -->
      <div class="md:col-span-7 md:col-start-3 space-y-8 md:mt-16 menu-reveal-node" style="transition-delay: 0.4s;">
        <!-- Format paysage panoramique luxueux pour le dernier plat -->
        <div class="relative aspect-video w-full overflow-hidden bg-neutral-950 border border-creme/5 group cursor-pointer">
          <img 
            src="/images/plats/plat-7.png" 
            alt="Le Ndolé d'Orfèvre" 
            class="w-full h-full object-cover opacity-75 group-hover:opacity-100 group-hover:scale-102 transition-all duration-1000 ease-out" 
          />
          <div class="absolute inset-0 bg-linear-to-t from-noir via-transparent to-transparent opacity-60 group-hover:opacity-20 transition-opacity duration-700"></div>
        </div>
        
        <div class="grid md:grid-cols-12 gap-4 pt-2">
          <div class="md:col-span-5">
            <h3 class="font-serif text-3xl font-light tracking-wide mb-1">Ndolé d'Orfèvre</h3>
            <span class="text-[9px] uppercase tracking-[0.3em] text-creme/30 font-semibold">Tradition Camerounaise</span>
          </div>
          <div class="md:col-span-7 space-y-3 md:text-right flex flex-col md:items-end">
            <span class="font-serif text-xl text-vin tracking-widest block">9 500 FCFA</span>
            <p class="text-creme/50 text-sm font-light leading-relaxed max-w-md">
              Feuilles amères de Ndolé minutieusement lavées, velouté d’arachides fraîches et noix de cajou torréfiées, escortées de reines crevettes snackées au beurre de karité clarifié.
          </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // Intersection Observer de haute précision pour un effet d'apparition séquentiel
  const premiumOptions = {
    root: null,
    rootMargin: '-40px 0px', // Se déclenche légèrement avant l'entrée complète pour plus de fluidité
    threshold: 0.05
  };

  const premiumObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const nodes = entry.target.querySelectorAll('.menu-reveal-node');
        nodes.forEach((node) => node.classList.add('reveal-active'));
        premiumObserver.unobserve(entry.target);
      }
    });
  }, premiumOptions);

  const containerTarget = document.getElementById('premium-menu-observer');
  if (containerTarget) {
    premiumObserver.observe(containerTarget);
  }
</script>

<style is:global>
  /* Structure et typographie de luxe cinématique */
  .menu-reveal-node {
    opacity: 0;
    transform: translateY(50px);
    filter: blur(8px);
    transition: transform 1.6s cubic-bezier(0.19, 1, 0.22, 1),
                opacity 1.6s cubic-bezier(0.19, 1, 0.22, 1),
                filter 1.6s cubic-bezier(0.19, 1, 0.22, 1);
    will-change: transform, opacity, filter;
  }

  /* Révélation d'une douceur absolue */
  .menu-reveal-node.reveal-active {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /* Teinte subtile sur l'image pour le style éditorial */
  .contrast-110 {
    filter: contrast(1.05) brightness(0.9);
  }
</style>
