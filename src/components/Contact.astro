---
// Section Contact & Réservation - FoodHouse
---

<section id="reservation" class="py-28 md:py-40 bg-vin relative overflow-hidden text-creme">
  
  <!-- Brume lumineuse subtile -->
  <div class="absolute top-0 left-0 w-full h-64 bg-noir/10 pointer-events-none"></div>
  <div class="absolute -bottom-32 -right-32 w-96 h-96 bg-noir/20 rounded-full filter blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10" id="contact-observer">
    
    <!-- En-tête -->
    <div class="text-center mb-20 contact-reveal">
      <span class="uppercase tracking-[0.6em] text-[9px] text-creme/60 font-bold block mb-3">Nous trouver</span>
      <h2 class="font-serif text-5xl md:text-7xl font-extralight tracking-tight leading-none">
        Réservez <span class="italic font-light text-creme/80">votre table</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-16 items-start">
      
      <!-- Colonne gauche : Formulaire -->
      <div class="contact-reveal" style="transition-delay: 0.1s;">
        <form id="reservation-form" class="space-y-6" onsubmit="return sendToWhatsApp(event)">
          <div>
            <label for="name" class="block text-xs uppercase tracking-[0.2em] text-creme/70 mb-2">Nom complet</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required 
              placeholder="Votre nom"
              class="w-full bg-transparent border border-creme/30 rounded-lg px-5 py-4 text-creme placeholder-creme/30 focus:outline-none focus:border-creme/60 transition-colors"
            />
          </div>
          <div>
            <label for="phone" class="block text-xs uppercase tracking-[0.2em] text-creme/70 mb-2">Téléphone</label>
            <input 
              type="tel" 
              id="phone" 
              name="phone" 
              required 
              placeholder="+229 01 96 97 72 15"
              class="w-full bg-transparent border border-creme/30 rounded-lg px-5 py-4 text-creme placeholder-creme/30 focus:outline-none focus:border-creme/60 transition-colors"
            />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="date" class="block text-xs uppercase tracking-[0.2em] text-creme/70 mb-2">Date</label>
              <input 
                type="date" 
                id="date" 
                name="date" 
                required 
                class="w-full bg-transparent border border-creme/30 rounded-lg px-5 py-4 text-creme placeholder-creme/30 focus:outline-none focus:border-creme/60 transition-colors"
              />
            </div>
            <div>
              <label for="couverts" class="block text-xs uppercase tracking-[0.2em] text-creme/70 mb-2">Couverts</label>
              <select 
                id="couverts" 
                name="couverts" 
                required 
                class="w-full bg-noir/20 border border-creme/30 rounded-lg px-5 py-4 text-creme focus:outline-none focus:border-creme/60 transition-colors"
              >
                <option value="1">1 personne</option>
                <option value="2" selected>2 personnes</option>
                <option value="3">3 personnes</option>
                <option value="4">4 personnes</option>
                <option value="5">5 personnes</option>
                <option value="6+">6+ personnes</option>
              </select>
            </div>
          </div>
          <div>
            <label for="message" class="block text-xs uppercase tracking-[0.2em] text-creme/70 mb-2">Message (optionnel)</label>
            <textarea 
              id="message" 
              name="message" 
              rows="3" 
              placeholder="Une demande particulière ?"
              class="w-full bg-transparent border border-creme/30 rounded-lg px-5 py-4 text-creme placeholder-creme/30 focus:outline-none focus:border-creme/60 transition-colors"
            ></textarea>
          </div>
          <button 
            type="submit" 
            class="w-full bg-white text-vin font-semibold py-4 px-8 rounded-full hover:bg-creme transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-white/20 flex items-center justify-center gap-3"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><path d="M22 2L15 22L11 13 2 9 22 2z"/></svg>
            Réserver via WhatsApp
          </button>
        </form>
      </div>

      <!-- Colonne droite : Infos & Carte -->
      <div class="space-y-12 contact-reveal" style="transition-delay: 0.3s;">
        <!-- Bloc adresse -->
        <div class="flex items-start gap-5">
          <div class="w-12 h-12 rounded-full bg-creme/10 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <h3 class="font-serif text-xl mb-1">Adresse</h3>
            <p class="text-creme/60 text-sm leading-relaxed">Porto-Novo<br />République du Bénin</p>
          </div>
        </div>

        <!-- Bloc téléphone -->
        <div class="flex items-start gap-5">
          <div class="w-12 h-12 rounded-full bg-creme/10 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <h3 class="font-serif text-xl mb-1">Téléphone</h3>
            <a href="tel:+2290196977215" class="text-creme/60 text-sm hover:text-creme transition-colors block">+229 01 96 97 72 15</a>
          </div>
        </div>

        <!-- Bloc horaires -->
        <div class="flex items-start gap-5">
          <div class="w-12 h-12 rounded-full bg-creme/10 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <h3 class="font-serif text-xl mb-1">Horaires</h3>
            <p class="text-creme/60 text-sm leading-relaxed">
              Lun – Ven : 12h00 – 15h00, 19h00 – 23h00<br />
              Samedi : 19h00 – 00h00<br />
              Dimanche : Fermé
            </p>
          </div>
        </div>

        <!-- Réseaux sociaux -->
        <div class="flex gap-4 pt-4">
          <a href="#" aria-label="Instagram" class="w-10 h-10 rounded-full border border-creme/30 flex items-center justify-center hover:border-creme hover:bg-creme/10 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" aria-label="Facebook" class="w-10 h-10 rounded-full border border-creme/30 flex items-center justify-center hover:border-creme hover:bg-creme/10 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="#" aria-label="TikTok" class="w-10 h-10 rounded-full border border-creme/30 flex items-center justify-center hover:border-creme hover:bg-creme/10 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 8 0 4 4 0 0 0-8 0z"/><path d="M15 8h.01"/></svg>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
<script is:inline>
  function sendToWhatsApp(event) {
    event.preventDefault();
    const form = document.getElementById('reservation-form');
    const formData = new FormData(form);
    const name = formData.get('name');
    const phone = formData.get('phone');
    const date = formData.get('date');
    const couverts = formData.get('couverts');
    const message = formData.get('message') || 'Aucune';

    // Formatage lisible de la date (JJ/MM/AAAA)
    const [year, month, day] = date.split('-');
    const dateFormatted = `${day}/${month}/${year}`;

    const whatsappNumber = '2290196977215'; // Numéro WhatsApp de FoodHouse (Porto-Novo, Bénin)

    // Utilisation de vrais retours à la ligne (\n), pas de "%0A" en texte
    const rawText =
`Nouvelle réservation FoodHouse

Nom : ${name}
Téléphone : ${phone}
Date : ${dateFormatted}
Nombre de couverts : ${couverts}
Message : ${message}`;

    const text = encodeURIComponent(rawText);

    window.open(`https://wa.me/${whatsappNumber}?text=${text}`, '_blank');
    return false;
  }
</script>

<style is:global>
  .contact-reveal {
    opacity: 0;
    transform: translateY(30px);
    filter: blur(4px);
    transition: transform 1.2s cubic-bezier(0.19, 1, 0.22, 1),
                opacity 1.2s cubic-bezier(0.19, 1, 0.22, 1),
                filter 1.2s cubic-bezier(0.19, 1, 0.22, 1);
    will-change: transform, opacity, filter;
  }
  .contact-reveal.reveal-active {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /* Amélioration des champs date et select */
  input[type="date"]::-webkit-calendar-picker-indicator {
    filter: invert(0.8);
  }
</style>

<script is:inline>
  // Intersection Observer pour la révélation
  const contactObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const nodes = entry.target.querySelectorAll('.contact-reveal');
        nodes.forEach((node) => node.classList.add('reveal-active'));
        contactObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  const contactTarget = document.getElementById('contact-observer');
  if (contactTarget) {
    contactObserver.observe(contactTarget);
  }
</script>